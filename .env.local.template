# Copy this file to .env.local and fill values.
# .env.local is already git-ignored.

# Google Maps (public key used in the browser)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Gemini (server-side)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Chat logging -> Google Sheets (Apps Script Web App)
# After deploying your Apps Script as a Web App, paste its URL here.
CHAT_LOG_WEBHOOK_URL=

# Optional: must match the Apps Script Script Property LOG_TOKEN.
# If you leave LOG_TOKEN empty in Apps Script, you can leave this empty too.
CHAT_LOG_WEBHOOK_TOKEN=

# Alternative (no external API): log to local file (JSONL)
# Works only on persistent disk (self-host/VPS), not most serverless hosts.
CHAT_LOG_FILE_PATH=./logs/chat-log.jsonl

# Chat logging (recommended for production): Postgres
# Example: Supabase/Neon connection string
CHAT_LOG_DATABASE_URL=

# Admin login
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Any long random string
ADMIN_SESSION_SECRET=abcdefghijklmnopqrstuvwxyz1234567890
