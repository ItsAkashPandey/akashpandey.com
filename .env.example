RESEND_API_KEY=

# Google Maps (public)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Chat logging (Google Sheets via Apps Script Web App)
# 1) Create Apps Script bound to your spreadsheet, deploy as Web App
# 2) Set these:
CHAT_LOG_WEBHOOK_URL=
CHAT_LOG_WEBHOOK_TOKEN=
# If you don't want to use a token, leave CHAT_LOG_WEBHOOK_TOKEN empty and also leave LOG_TOKEN empty in Apps Script.

# Chat logging (no external API): local JSONL file path
# NOTE: Only reliable when running on a server with persistent disk (not most serverless hosts).
CHAT_LOG_FILE_PATH=./logs/chat-log.jsonl

# Chat logging (recommended for production): Postgres
CHAT_LOG_DATABASE_URL=

# Admin login (to view chat logs)
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
# Apps Script Script Properties you should set (not used by Next directly):
# SPREADSHEET_ID=1bCBque_VTCOF2ygH-5nZG5VSyq-Mh-gJ0900p3ZplUU
# SHEET_NAME=chat_logs

TACOS_API_URL=
TACOS_API_KEY=

REVALIDATE_SECRET=